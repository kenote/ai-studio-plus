{
  "name": "ai-studio-plus",
  "description": "基于 Vue 3 + TypeScript 构建的 AI 智能对话应用，支持多 AI 提供方管理和联网搜索功能。",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:ssr": "vite build",
    "build:spa": "vite build --config vite.spa.config.ts",
    "build:prod": "run-p type-check build:spa && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "axios": "^1.14.0",
    "connect": "^3.7.0",
    "dexie": "^4.4.2",
    "element-plus": "^2.13.6",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "less": "^4.6.4",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.2",
    "mitt": "^3.0.1",
    "pinia": "^3.0.4",
    "sirv": "^3.0.2",
    "unocss": "66.6.0",
    "vite-plugin-ssr": "^0.4.142",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.0",
    "@unocss/preset-icons": "66.6.0",
    "@unocss/preset-uno": "66.6.0",
    "@unocss/transformer-directives": "^66.6.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": "https://github.com/kenote/ai-studio-plus.git",
  "author": "thondery <thondery@163.com>",
  "license": "MIT"
}
